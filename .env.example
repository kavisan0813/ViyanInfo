# EmailJS Configuration File Template
# Copy these values into a .env file in the root directory to activate live email routing

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_HR_ID=your_hr_notification_template_id
VITE_EMAILJS_TEMPLATE_APPLICANT_ID=your_applicant_confirmation_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=udtc1usd
VITE_CLOUDINARY_UPLOAD_PRESET=ml_default    